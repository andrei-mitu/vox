NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: Auth Admin API (Dashboard → Settings → API → service_role). Never commit real values.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local seed: bun run seed:admin — creates or updates this user (password reset on re-run).
# Password must match login validation: 8+ chars, one A–Z, one digit.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe1
