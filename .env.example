# Direct PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#
# Docker Compose (pre-configured in docker-compose.yml — no edit needed):
#   postgresql://vox:vox_dev_password@postgres:5432/vox
#
# Local dev (edit to match your local PostgreSQL):
DATABASE_URL=postgresql://postgres:password@localhost:5432/vox

# HS256 signing key for JWT session tokens.
# Generate: openssl rand -base64 32   (must be ≥32 characters)
# Never use this placeholder in production.
JWT_SECRET=change-me-to-a-random-secret

# Dev seed defaults — used only by bun run db:seed (001_admin.sql).
# The password is hashed via bcrypt inside the seed script.
# SEED_ADMIN_EMAIL=admin@admin.com
# SEED_ADMIN_PASSWORD=Admin.123
