# Direct PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# On Supabase: Project Settings → Database → Connection string (URI mode, port 5432).
DATABASE_URL=postgresql://postgres:password@localhost:5432/vox

# Secret used to sign JWT session tokens. Generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-secret

# Local seed defaults — only used by bun run db:seed (001_admin.sql).
# The password is hashed via pgcrypto inside the SQL file; these vars are for documentation only.
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=ChangeMe1
