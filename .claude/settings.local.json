{
  "permissions": {
    "allow": [
      "Bash(winget upgrade:*)",
      "Bash(bun run:*)",
      "Bash(bun remove:*)",
      "Bash(bun add:*)",
      "Bash(mv:*)",
      "Bash(cp -r \"app/\\(login\\)\" \"app/\\(auth\\)\")",
      "Bash(rm -rf \"app/\\(login\\)\")",
      "Bash(mkdir -p components/theme)",
      "Bash(cp components/ThemeToggle.tsx components/theme/theme-toggle.tsx)",
      "Bash(cp components/ThemeProvider.tsx components/theme/theme-provider.tsx)",
      "Bash(rm components/ThemeToggle.tsx components/ThemeProvider.tsx)",
      "Bash(sed -i \"s|@/components/ThemeToggle|@/components/theme/theme-toggle|g\" \"app/\\(auth\\)/layout.tsx\" components/sidebar/sidebar.tsx)",
      "Bash(sed -i \"s|@/components/ThemeProvider|@/components/theme/theme-provider|g\" app/layout.tsx)",
      "Bash(rm:*)",
      "WebSearch",
      "Bash(xargs grep:*)",
      "Bash(bunx eslint:*)",
      "Bash(ls .claude/)",
      "Bash(cat .claude/settings.local.json)",
      "Bash(bunx biome:*)",
      "Bash(bun run typecheck)",
      "Bash(bunx jq:*)",
      "Bash(find \"app/\\(dashboard\\)/[workspace]/admin\" -type f)",
      "Bash(find \"app/api/[workspace]/admin\" -type f)",
      "WebFetch(domain:github.com)",
      "Bash(npx tsc *)",
      "Bash(node_modules/.bin/tsc --noEmit)",
      "Read(//c/Users/andrei/.claude/plugins/cache/caveman/caveman/84cc3c14fa1e/skills/compress/**)",
      "Bash(python3 -m scripts \"D:\\\\projects\\\\vox\\\\vox\\\\AGENTS.md\")",
      "Bash(python -m scripts \"D:\\\\projects\\\\vox\\\\vox\\\\AGENTS.md\")",
      "Bash(py -m scripts \"D:\\\\projects\\\\vox\\\\vox\\\\AGENTS.md\")",
      "Bash(git -C \"D:\\\\projects\\\\vox\\\\vox\" diff --staged)",
      "Bash(git -C \"D:\\\\projects\\\\vox\\\\vox\" status --short)",
      "Bash(node -e ' *)",
      "Bash(bun -e ' *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"$CLAUDE_TOOL_INPUT_FILE_PATH\"; [[ \"$f\" == *.ts || \"$f\" == *.tsx ]] && bunx biome format --write \"$f\" && bunx biome lint --write \"$f\" || true'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cd \"$CLAUDE_PROJECT_DIR\" && bun run typecheck 2>&1 | tail -5'"
          }
        ]
      }
    ]
  }
}
